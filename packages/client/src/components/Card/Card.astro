---
// Reusable Card component for projects and articles
export interface Props {
  title: string;
  description: string;
  link: string;
  linkText: string;
  image?: string;
  imageAlt?: string;
}

const { title, description, link, linkText, image, imageAlt } = Astro.props;
import styles from './Card.module.scss';
---
<div class={styles.card}>
  {image && <div class={styles.cardImage}><img src={image} alt={imageAlt || title} /></div>}
  <div class={styles.cardContent}>
    <h3 class={styles.cardTitle}>{title}</h3>
    <p class={styles.cardDescription}>{description}</p>
    <a href={link} class={styles.cardLink}>{linkText}</a>
  </div>
</div>
