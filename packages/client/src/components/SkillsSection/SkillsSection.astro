---
// Skills section for homepage
import styles from './SkillsSection.module.scss';
import SectionTitle from './../SectionTitle/SectionTitle.astro';
import * as skillsData from '../../../content/skills.md';

const { title, skills, softskills } = skillsData.frontmatter;
---
<section class={styles.skillsSection}>
  <div class={styles.skillsContainer}>
    <SectionTitle>{title}</SectionTitle>
    <p class={styles.skillsText}>
      {skills && skills.join(', ')}
    </p>
    <p class={styles.skillsText}>
      {softskills}
    </p>
  </div>
</section> 